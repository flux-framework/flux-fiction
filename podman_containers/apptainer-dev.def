BootStrap: docker
From: ubuntu:24.04

%files
    scripts/flux-dev-env.sh /usr/local/bin/flux-dev-env.sh
    scripts/build-flux-core.sh /usr/local/bin/build-flux-core.sh
    scripts/build-flux-sched.sh /usr/local/bin/build-flux-sched.sh
    scripts/build-flux-fiction.sh /usr/local/bin/build-flux-fiction.sh
    scripts/build-flux-stack.sh /usr/local/bin/build-flux-stack.sh
    scripts/flux-dev-profile.sh /etc/profile.d/flux-dev.sh

%post
    export DEBIAN_FRONTEND=noninteractive
    export LC_ALL=C
    export LANG=C
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export CC=gcc-12
    export CXX=g++-12

    echo 'APT::Sandbox::User root;' > /etc/apt/apt.conf.d/00-apt-sandbox
    apt-get update && \
    apt-get install -y \
        autoconf \
        automake \
        libtool \
        build-essential \
        make \
        cmake \
        meson \
        ninja-build \
        pkg-config \
        gcc \
        g++ \
        gcc-12 \
        g++-12 \
        cpp-12 \
        gfortran \
        git \
        wget \
        curl \
        vim \
        less \
        file \
        jq \
        ca-certificates \
        time \
        valgrind \
        aspell \
        aspell-en \
        fakeroot \
        libfaketime \
        libc6-dev \
        libzmq3-dev \
        uuid-dev \
        libjansson-dev \
        liblz4-dev \
        libarchive-dev \
        libhwloc-dev \
        libsqlite3-dev \
        lua5.1 \
        liblua5.1-dev \
        lua-posix \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        python3-cffi \
        python3-ply \
        python3-setuptools \
        python3-yaml \
        python3-sphinx \
        python3-wheel \
        python3-pytest \
        python3-pytest-cov \
        python3-matplotlib \
        python3-tqdm \
        python3-pydantic \
        python3-tomli \
        python3-jsonschema \
        libmpich-dev \
        libboost-dev \
        libboost-graph-dev \
        libedit-dev \
        libyaml-cpp-dev \
        tmux \
        strace && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    python3 -m pip install --break-system-packages \
        build \
        meson-python \
        opentelemetry-api \
        opentelemetry-sdk \
        opentelemetry-exporter-otlp-proto-http

    mkdir -p /work /data /output /scratch /workspace

    chmod +x \
        /usr/local/bin/flux-dev-env.sh \
        /usr/local/bin/build-flux-core.sh \
        /usr/local/bin/build-flux-sched.sh \
        /usr/local/bin/build-flux-fiction.sh \
        /usr/local/bin/build-flux-stack.sh

%environment
    export LC_ALL=C
    export LANG=C
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export CC=gcc-12
    export CXX=g++-12

%runscript
    exec /bin/bash -l "$@"
