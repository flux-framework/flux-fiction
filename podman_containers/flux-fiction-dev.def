BootStrap: docker
From: ubuntu:24.04

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y \
        autoconf \
        automake \
        libtool \
        build-essential \
        make \
        cmake \
        meson \
        ninja-build \
        pkg-config \
        gcc \
        g++ \
        gcc-12 \
        g++-12 \
        cpp-12 \
        gfortran \
        git \
        wget \
        curl \
        vim \
        less \
        file \
        jq \
        ca-certificates \
        time \
        valgrind \
        aspell \
        aspell-en \
        fakeroot \
        libfaketime \
        libc6-dev \
        libzmq3-dev \
        uuid-dev \
        libjansson-dev \
        liblz4-dev \
        libarchive-dev \
        libhwloc-dev \
        libsqlite3-dev \
        lua5.1 \
        liblua5.1-dev \
        lua-posix \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        python3-cffi \
        python3-ply \
        python3-setuptools \
        python3-yaml \
        python3-sphinx \
        python3-wheel \
        python3-tqdm \
        python3-pydantic \
        python3-tomli \
        python3-jsonschema \
        libmpich-dev \
        libboost-dev \
        libboost-graph-dev \
        libedit-dev \
        libyaml-cpp-dev \
        tmux \
        strace \


    apt-get clean
    rm -rf /var/lib/apt/lists/*

    mkdir -p /work /data /output /scratch

    cat > /usr/local/bin/flux-dev-env.sh <<'EOF'
#!/bin/bash
export FLUX_PREFIX=/work/flux/sc25_poster/container-installs/flux-core
export PATH="$FLUX_PREFIX/bin:$PATH"
export LD_LIBRARY_PATH="$FLUX_PREFIX/lib:$FLUX_PREFIX/lib64:${LD_LIBRARY_PATH:-}"
export PKG_CONFIG_PATH="$FLUX_PREFIX/lib/pkgconfig:$FLUX_PREFIX/lib64/pkgconfig:${PKG_CONFIG_PATH:-}"
export CC=gcc-12
export CXX=g++-12

if command -v flux >/dev/null 2>&1; then
    eval "$(flux env)" 2>/dev/null || true
fi
EOF
    chmod +x /usr/local/bin/flux-dev-env.sh

    cat > /usr/local/bin/build-flux-stack.sh <<'EOF'
#!/bin/bash
set -euo pipefail

export SRC_ROOT=/work/flux/sc25_poster
export INSTALL_ROOT="$SRC_ROOT/container-installs"
export FLUX_PREFIX="$INSTALL_ROOT/flux-core"

mkdir -p "$INSTALL_ROOT/flux-core"

# Build / install flux-core
cd "$SRC_ROOT/flux-core-updated/flux-core"
make distclean || true
./autogen.sh
CC=gcc-12 CXX=g++-12 ./configure --prefix="$FLUX_PREFIX"
make -j"$(nproc)"
make install

export PATH="$FLUX_PREFIX/bin:$PATH"
export LD_LIBRARY_PATH="$FLUX_PREFIX/lib:$FLUX_PREFIX/lib64:${LD_LIBRARY_PATH:-}"
export PKG_CONFIG_PATH="$FLUX_PREFIX/lib/pkgconfig:$FLUX_PREFIX/lib64/pkgconfig:${PKG_CONFIG_PATH:-}"

# Build / install flux-sched into same prefix
cd "$SRC_ROOT/flux-sched"
rm -rf build
mkdir -p build
cd build
CC=gcc-12 CXX=g++-12 cmake .. \
  -DCMAKE_INSTALL_PREFIX="$FLUX_PREFIX" \
  -DCMAKE_PREFIX_PATH="$FLUX_PREFIX"
make -j"$(nproc)"
make install

# Build the flux-fiction jobtap plugin
cd "$SRC_ROOT/flux-fiction"
rm -rf build
mkdir -p build
cd build
CC=gcc-12 cmake .. 
make

echo adding Flux to bashrc

echo
echo "Build complete."
echo "flux-core + flux-sched installed to: $FLUX_PREFIX"
echo "jobtap plugin built at: $SRC_ROOT/flux-fiction/build/emu-jobtap.so"
EOF
    chmod +x /usr/local/bin/build-flux-stack.sh

%environment
    export LC_ALL=C
    export LANG=C
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export CC=gcc-12
    export CXX=g++-12

%runscript
    exec /bin/bash "$@"